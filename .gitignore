/target
/dist
# scripts/audit-vms.sh output: throwaway VM disks + per-run logs/screenshots,
# fully reproducible — never commit (the .vdi files are multi-GB each).
/audit-results/

# marketplace/cache-proxy.py: the package cache (multi-GB) and its log
/marketplace/pkg-cache/
/marketplace/cache-proxy.log
# boot-test / server.py throwaway + kept VM disks (multi-GB, reproducible)
/marketplace/*.vdi
# server.py per-job temp submission files (written + reaped at runtime)
/marketplace/.review-*.json
__pycache__/
**/*.rs.bk
*.pdb
Cargo.lock.bak

# Local agent notes — kept on disk, not shared to the remote.
CLAUDE.md

# Editor / OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
.claude/
vendor-archiso/

# Packaging: built packages + the repo db live on the GitHub release, not in git.
packaging/out/
packaging/pkg/*.tar.gz
packaging/pkg/src/
packaging/pkg/pkg/
packaging/keyring/src/
packaging/keyring/pkg/
*.pkg.tar.zst
*.pkg.tar.zst.sig
# NEVER commit private key material (gen-key.sh never writes these into the
# repo; this is a second line of defence against a stray manual export).
*.sec.asc
*.sec.gpg
*secring*
*private*.asc

# ISO build artifacts
iso/work/
iso/out/
iso/manifest-os/airootfs/usr/local/bin/manifest

iso/manifest-os/airootfs/usr/share/manifest-os/
# Prebuilt paru baked into the live ISO's pacman cache so a fresh install skips
# the 20-30 min source build (bootstrap_paru picks it up, verifies it runs, and
# falls back to a source build if the ABI moved). Large + machine-specific.
iso/manifest-os/airootfs/var/cache/pacman/pkg/
vmdisks/
