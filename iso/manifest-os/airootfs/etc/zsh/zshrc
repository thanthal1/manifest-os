# ManifestOS live session — zsh global rc.
# Load the strata command-not-found handler so typing an uninstalled `apt`/`dnf`
# in the live environment offers to add that distro (installed systems get the
# same via `strata::write_cnf_handler`). zsh never sources /etc/profile.d, so it
# must be wired here.
[ -r /etc/manifest-os/strata-cnf.sh ] && . /etc/manifest-os/strata-cnf.sh  # manifest-os-strata-cnf
